{
    "name": "managpro/backend",
    "description": "ManagPro Backend - CodeIgniter4",
    "license": "MIT",
    "type": "project",
    "require": {
        "php": "^8.1",
        "aws/aws-sdk-php": "^3.387",
        "codeigniter4/framework": "^4.7",
        "firebase/php-jwt": "^6.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.9",
        "mikey179/vfsstream": "^1.6",
        "phpstan/phpstan": "^1.10",
        "friendsofphp/php-cs-fixer": "^3.40",
        "phpunit/phpunit": "^10.5.16"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Config\\": "app/Config/",
            "Module\\": "Module/",
            "Sites\\": "Sites/"
        },
        "exclude-from-classmap": [
            "**/Database/Migrations/**"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\Support\\": "tests/_support"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse Module Sites --level=5",
        "cs-fix": "php-cs-fixer fix --allow-risky=yes"
    }
}
