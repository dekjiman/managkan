{
  "info": {
    "name": "{Project Name} — {API Scope}",
    "description": "# {Project Name} API Collection\n\n{1-2 kalimat deskripsi API ini}\n\n## Auth\n\nSemua endpoint (kecuali login) memerlukan Bearer token.\n\n## Base URL\n\n`{{base_url}}` — dikonfigurasi di environment.\n\n## Rate Limit\n\n{rate limit info}",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{auth_token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Auth",
      "description": "Authentication endpoints — login, profile, logout",
      "item": [
        {
          "name": "Login",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\",\n  \"device_name\": \"{{device_name}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.data && response.data.token) {",
                  "  pm.environment.set('auth_token', response.data.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Profile",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/auth/profile",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "profile"]
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/auth/logout",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "auth", "logout"]
            }
          }
        }
      ]
    },
    {
      "name": "{Modul 1}",
      "description": "{deskripsi modul}",
      "item": [
        {
          "name": "List {Resource}",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/{prefix}?page=1&per_page=20",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "{prefix}"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "per_page", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Show {Resource}",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/{prefix}/{{id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "{prefix}", "{{id}}"]
            }
          }
        },
        {
          "name": "Create {Resource}",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"example\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/{prefix}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "{prefix}"]
            }
          }
        },
        {
          "name": "Update {Resource}",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"updated\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/{prefix}/{{id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "{prefix}", "{{id}}"]
            }
          }
        },
        {
          "name": "Delete {Resource}",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/{prefix}/{{id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "{prefix}", "{{id}}"]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "{{base_url}}",
      "type": "string"
    }
  ]
}
